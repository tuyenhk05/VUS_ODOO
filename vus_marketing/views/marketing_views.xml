<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Giao diện Form Chiến dịch Marketing -->
    <record id="view_vus_marketing_campaign_form" model="ir.ui.view">
        <field name="name">vus.marketing.campaign.form</field>
        <field name="model">vus.marketing.campaign</field>
        <field name="arch" type="xml">
            <form string="Chiến dịch Marketing">
                <header>
                    <button name="action_start" string="Bắt đầu" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_complete" string="Hoàn thành" type="object" class="oe_highlight" invisible="state != 'running'"/>
                    <button name="action_create_targeted_email" string="Gửi Email Hướng Mục Tiêu" type="object" class="btn-primary" invisible="state not in ['draft', 'running']"/>
                    <button name="action_cancel" string="Hủy" type="object" invisible="state not in ('draft', 'running')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,running,completed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(crm.crm_lead_action_pipeline)d" type="action" class="oe_stat_button" icon="fa-users" context="{'search_default_vus_campaign_id': active_id}">
                            <field name="lead_count" widget="statinfo" string="Số Lead"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Tên chiến dịch..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Thông tin chung">
                            <field name="code"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="channel_ids" widget="many2many_tags"/>
                            <field name="audience_ids" widget="many2many_tags"/>
                        </group>
                        <group string="Tài chính &amp; Ngân sách">
                            <field name="currency_id" invisible="1"/>
                            <field name="budget" widget="monetary"/>
                            <field name="actual_cost" widget="monetary"/>
                            <field name="target_leads"/>
                        </group>
                    </group>
                    <group string="Chỉ số hiệu năng hiệu quả (KPIs)">
                        <group>
                            <field name="lead_count" string="Số Lead thực tế"/>
                            <field name="cost_per_lead" widget="monetary" readonly="1"/>
                        </group>
                        <group>
                            <field name="conversion_count" string="Số học viên chuyển đổi"/>
                            <field name="conversion_rate" string="Tỷ lệ chuyển đổi (%)" widget="progressbar"/>
                            <field name="total_revenue" widget="monetary" readonly="1"/>
                            <field name="roi" string="Chỉ số ROI (%)" widget="percentage" decoration-danger="roi &lt; 0" decoration-success="roi &gt;= 0"/>
                        </group>
                    </group>
                    <group string="Thống kê Email Marketing">
                        <group>
                            <field name="email_sent" readonly="1"/>
                            <field name="email_opened" readonly="1"/>
                            <field name="email_clicked" readonly="1"/>
                        </group>
                        <group>
                            <field name="email_open_rate" widget="progressbar" readonly="1"/>
                            <field name="email_click_rate" widget="progressbar" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mô tả chi tiết" name="description">
                            <field name="description" placeholder="Nhập mô tả chi tiết chiến dịch tại đây..."/>
                        </page>
                        <page string="Danh sách Leads tuyển sinh" name="leads">
                            <field name="lead_ids" readonly="1">
                                <tree>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="lead_source"/>
                                    <field name="stage_id"/>
                                    <field name="expected_revenue"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Chiến dịch Email Marketing" name="mass_mailings">
                            <field name="mailing_ids" readonly="1">
                                <tree>
                                    <field name="subject"/>
                                    <field name="sent"/>
                                    <field name="opened"/>
                                    <field name="clicked"/>
                                    <field name="bounced"/>
                                    <field name="received_ratio" widget="progressbar" string="Tỷ lệ nhận (%)"/>
                                    <field name="clicks_ratio" widget="progressbar" string="Tỷ lệ click (%)"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Kế thừa giao diện Email Marketing Form để hiển thị trường Chiến dịch VUS -->
    <record id="view_mail_mass_mailing_form_inherit_vus" model="ir.ui.view">
        <field name="name">mailing.mailing.form.inherit.vus</field>
        <field name="model">mailing.mailing</field>
        <field name="inherit_id" ref="mass_mailing.view_mail_mass_mailing_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='campaign_id']" position="after">
                <field name="vus_campaign_id" string="Chiến dịch VUS"/>
            </xpath>
        </field>
    </record>

    <!-- Giao diện Tree Chiến dịch Marketing -->
    <record id="view_vus_marketing_campaign_tree" model="ir.ui.view">
        <field name="name">vus.marketing.campaign.tree</field>
        <field name="model">vus.marketing.campaign</field>
        <field name="arch" type="xml">
            <tree string="Chiến dịch Marketing" decoration-info="state == 'running'" decoration-success="state == 'completed'" decoration-muted="state == 'cancelled'">
                <field name="code"/>
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="budget"/>
                <field name="actual_cost"/>
                <field name="lead_count"/>
                <field name="cost_per_lead"/>
                <field name="conversion_count"/>
                <field name="conversion_rate"/>
                <field name="total_revenue"/>
                <field name="roi"/>
                <field name="state" widget="badge" decoration-info="state == 'running'" decoration-success="state == 'completed'" decoration-muted="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- Hành động Quản lý Chiến dịch -->
    <record id="action_vus_marketing_campaign" model="ir.actions.act_window">
        <field name="name">Chiến dịch Marketing</field>
        <field name="res_model">vus.marketing.campaign</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo chiến dịch Marketing mới của VUS!
            </p>
        </field>
    </record>

    <!-- Kế thừa giao diện CRM Lead Form -->
    <record id="crm_lead_view_form_inherit_vus_marketing" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.vus.marketing</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- Nút bấm đặt lịch thi xếp lớp nhanh từ thanh công cụ CRM -->
            <xpath expr="//header" position="inside">
                <button name="action_book_placement_test" type="object" string="Đăng ký thi xếp lớp" class="oe_highlight" invisible="probability == 100"/>
            </xpath>
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="vus_campaign_id"/>
                <field name="lead_source"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="VUS Chăm sóc &amp; Tuyển sinh" name="vus_marketing_info">
                    <group>
                        <field name="follow_up_notes" placeholder="Nhập thông tin chi tiết quá trình gọi điện chăm sóc, tư vấn học viên..."/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Kế thừa CRM Search View -->
    <record id="view_crm_case_opportunities_filter_inherit_vus_marketing" model="ir.ui.view">
        <field name="name">crm.lead.search.inherit.vus.marketing</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.view_crm_case_opportunities_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='stage']" position="before">
                <filter string="Chiến dịch VUS" name="groupby_vus_campaign" context="{'group_by':'vus_campaign_id'}"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="vus_campaign_id"/>
                <field name="lead_source"/>
            </xpath>
        </field>
    </record>

    <!-- Kế thừa Partner Form để hiển thị Phân loại đối tượng VUS -->
    <record id="view_partner_form_inherit_vus_marketing" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.vus.marketing</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="marketing_audience_ids" widget="many2many_tags" placeholder="Phân loại đối tượng VUS..." invisible="not is_student and not is_teacher"/>
            </xpath>
        </field>
    </record>

    <!-- Định nghĩa Menus -->
    <menuitem id="menu_vus_marketing_root" name="Marketing" parent="vus_student.menu_vus_root" sequence="1"/>
    <menuitem id="menu_vus_marketing_campaign" name="Chiến dịch Marketing" parent="menu_vus_marketing_root" action="action_vus_marketing_campaign" sequence="10"/>
</odoo>
