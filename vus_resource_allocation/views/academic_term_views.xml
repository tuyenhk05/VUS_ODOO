<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vus_academic_term_tree" model="ir.ui.view">
        <field name="name">vus.academic.term.tree</field>
        <field name="model">vus.academic.term</field>
        <field name="arch" type="xml">
            <tree string="Kỳ học" decoration-info="state == 'registration'" decoration-success="state == 'active'" decoration-muted="state == 'completed'">
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="registration_deadline"/>
                <field name="state" 
                       widget="badge" 
                       decoration-info="state == 'registration'" 
                       decoration-success="state == 'active'" 
                       decoration-muted="state == 'completed'"
                       decoration-warning="state == 'draft'"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_vus_academic_term_form" model="ir.ui.view">
        <field name="name">vus.academic.term.form</field>
        <field name="model">vus.academic.term</field>
        <field name="arch" type="xml">
            <form string="Kỳ học">
                <header>
                    <button name="action_start_registration" string="Mở đăng ký lịch" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_activate" string="Khai giảng kỳ" type="object" class="oe_highlight" invisible="state != 'registration'"/>
                    <button name="action_complete" string="Kết thúc kỳ" type="object" class="oe_highlight" invisible="state != 'active'"/>
                    <button name="action_set_draft" string="Đặt về nháp" type="object" invisible="state == 'draft'" groups="vus_student.group_vus_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,registration,active,completed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="state != 'draft'"/>
                            <field name="registration_deadline" readonly="state not in ('draft', 'registration')"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="start_date" readonly="state != 'draft'"/>
                            <field name="end_date" readonly="state != 'draft'"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_vus_academic_term" model="ir.actions.act_window">
        <field name="name">Kỳ học VUS</field>
        <field name="res_model">vus.academic.term</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo Kỳ học mới tại đây.
            </p>
        </field>
    </record>
</odoo>
