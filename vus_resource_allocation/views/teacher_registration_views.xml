<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vus_teacher_registration_tree" model="ir.ui.view">
        <field name="name">vus.teacher.registration.tree</field>
        <field name="model">vus.teacher.registration</field>
        <field name="arch" type="xml">
            <tree string="Đăng ký lịch dạy">
                <field name="term_id"/>
                <field name="teacher_id"/>
                <field name="time_slot_ids" widget="many2many_tags"/>
                <field name="min_sessions"/>
                <field name="selected_sessions"/>
                <field name="state" 
                       widget="badge" 
                       decoration-info="state == 'submitted'" 
                       decoration-success="state == 'approved'" 
                       decoration-muted="state == 'draft'"/>
            </tree>
        </field>
    </record>

    <record id="view_vus_teacher_registration_form" model="ir.ui.view">
        <field name="name">vus.teacher.registration.form</field>
        <field name="model">vus.teacher.registration</field>
        <field name="arch" type="xml">
            <form string="Đăng ký lịch dạy">
                <header>
                    <button name="action_submit" type="object" string="Gửi duyệt" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Duyệt đăng ký" class="oe_highlight" invisible="state != 'submitted'" groups="vus_student.group_vus_manager"/>
                    <button name="action_set_draft" type="object" string="Đặt về nháp" invisible="state == 'draft'" groups="vus_student.group_vus_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved"/>
                </header>
                <sheet>
                    <field name="is_teacher_user" invisible="1"/>
                    <group>
                        <group>
                            <field name="term_id" readonly="state != 'draft'"/>
                            <field name="teacher_id" readonly="state != 'draft' or is_teacher_user"/>
                        </group>
                        <group>
                            <field name="min_sessions" readonly="state != 'draft'"/>
                            <field name="selected_sessions"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Khung giờ dạy rảnh đăng ký" name="time_slots">
                            <field name="time_slot_ids" readonly="state != 'draft'">
                                <tree>
                                    <field name="name"/>
                                    <field name="days_group"/>
                                    <field name="shift"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vus_teacher_registration" model="ir.actions.act_window">
        <field name="name">Đăng ký lịch dạy</field>
        <field name="res_model">vus.teacher.registration</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo phiếu đăng ký lịch dạy của giáo viên tại đây.
            </p>
        </field>
    </record>
</odoo>
