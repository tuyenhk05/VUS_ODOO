<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_vus_time_slot_tree" model="ir.ui.view">
        <field name="name">vus.time.slot.tree</field>
        <field name="model">vus.time.slot</field>
        <field name="arch" type="xml">
            <tree string="Khung giờ / Ca học">
                <field name="name"/>
                <field name="days_group"/>
                <field name="shift"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time" widget="float_time"/>
            </tree>
        </field>
    </record>

    <record id="view_vus_time_slot_form" model="ir.ui.view">
        <field name="name">vus.time.slot.form</field>
        <field name="model">vus.time.slot</field>
        <field name="arch" type="xml">
            <form string="Khung giờ / Ca học">
                <sheet>
                    <group>
                        <group>
                            <field name="days_group"/>
                            <field name="shift"/>
                        </group>
                        <group>
                            <field name="start_time" widget="float_time"/>
                            <field name="end_time" widget="float_time"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_vus_time_slot" model="ir.actions.act_window">
        <field name="name">Khung giờ / Ca học VUS</field>
        <field name="res_model">vus.time.slot</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo Khung giờ / Ca học chuẩn hóa tại đây.
            </p>
        </field>
    </record>
</odoo>
