<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_vus_attendance_tree" model="ir.ui.view">
        <field name="name">vus.attendance.tree</field>
        <field name="model">vus.attendance</field>
        <field name="arch" type="xml">
            <tree string="Điểm danh" 
                  decoration-success="status == 'present'" 
                  decoration-danger="status == 'absent'" 
                  decoration-warning="status == 'late'" 
                  decoration-info="status == 'permission'">
                <field name="date"/>
                <field name="student_id"/>
                <field name="class_id"/>
                <field name="status" widget="badge" 
                       decoration-success="status == 'present'" 
                       decoration-danger="status == 'absent'" 
                       decoration-warning="status == 'late'" 
                       decoration-info="status == 'permission'"/>
                <field name="note"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_vus_attendance_form" model="ir.ui.view">
        <field name="name">vus.attendance.form</field>
        <field name="model">vus.attendance</field>
        <field name="arch" type="xml">
            <form string="Điểm danh">
                <header>
                    <button name="action_confirm" string="Xác nhận điểm danh" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <group>
                        <group string="Thông tin lớp học">
                            <field name="class_id" placeholder="BƯỚC 1: Chọn lớp học trước..."/>
                            <field name="enrollment_id" placeholder="BƯỚC 2: Chọn học viên..."/>
                            <field name="teacher_id"/>
                        </group>
                        <group string="Thông tin buổi học">
                            <field name="date"/>
                            <field name="session"/>
                            <field name="status" widget="radio" options="{'horizontal': true}"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" placeholder="Nhập ghi chú nếu có..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_vus_attendance_search" model="ir.ui.view">
        <field name="name">vus.attendance.search</field>
        <field name="model">vus.attendance</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm điểm danh">
                <field name="student_id"/>
                <field name="class_id"/>
                <field name="date"/>
                <separator/>
                <filter name="group_by_class" string="Lớp học" context="{'group_by': 'class_id'}"/>
                <filter name="filter_today" string="Hôm nay" domain="[('date', '=', context_today())]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_vus_attendance" model="ir.actions.act_window">
        <field name="name">Điểm danh</field>
        <field name="res_model">vus.attendance</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Điểm danh học viên!
            </p>
        </field>
    </record>

    <!-- Sheet Tree View -->
    <record id="view_vus_attendance_sheet_tree" model="ir.ui.view">
        <field name="name">vus.attendance.sheet.tree</field>
        <field name="model">vus.attendance.sheet</field>
        <field name="arch" type="xml">
            <tree string="Bảng điểm danh lớp học" decoration-success="state == 'done'" decoration-info="state == 'draft'">
                <field name="name"/>
                <field name="class_id"/>
                <field name="teacher_id"/>
                <field name="date"/>
                <field name="session_progress"/>
                <field name="state" widget="badge" decoration-success="state == 'done'" decoration-info="state == 'draft'"/>
            </tree>
        </field>
    </record>

    <!-- Sheet Form View -->
    <record id="view_vus_attendance_sheet_form" model="ir.ui.view">
        <field name="name">vus.attendance.sheet.form</field>
        <field name="model">vus.attendance.sheet</field>
        <field name="arch" type="xml">
            <form string="Bảng điểm danh">
                <header>
                    <button name="action_load_students" string="Tải danh sách học viên" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_confirm" string="Xác nhận điểm danh" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="class_id" readonly="state == 'done'"/>
                            <field name="teacher_id"/>
                        </group>
                        <group>
                            <field name="date" readonly="state == 'done'"/>
                            <label for="session_number" string="Tiến độ buổi học"/>
                            <div class="o_row">
                                <field name="session_number" readonly="state == 'done'" class="oe_inline"/> / 
                                <field name="total_sessions" readonly="1" class="oe_inline"/>
                            </div>
                            <field name="session_progress" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Danh sách học viên" name="attendance_lines">
                            <field name="line_ids" readonly="state == 'done'">
                                <tree editable="bottom" create="false" delete="false">
                                    <field name="student_id" readonly="1"/>
                                    <field name="status"/>
                                    <field name="note"/>
                                    <field name="state" invisible="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Sheet Action -->
    <record id="action_vus_attendance_sheet" model="ir.actions.act_window">
        <field name="name">Điểm danh theo buổi</field>
        <field name="res_model">vus.attendance.sheet</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo bảng điểm danh mới cho lớp học!
            </p>
        </field>
    </record>

    <!-- Inherit Class Form to add Progress Info -->
    <record id="view_vus_class_form_inherit_attendance" model="ir.ui.view">
        <field name="name">vus.class.form.inherit.attendance</field>
        <field name="model">vus.class</field>
        <field name="inherit_id" ref="vus_class.view_vus_class_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='end_date']" position="after">
                <label for="completed_sessions" string="Tiến độ học tập"/>
                <div class="o_row">
                    <field name="completed_sessions" readonly="1" class="oe_inline"/> / 
                    <field name="total_sessions" readonly="1" class="oe_inline"/> Buổi đã học
                </div>
                <field name="sessions_progress" invisible="1"/>
            </xpath>
        </field>
    </record>

</odoo>
