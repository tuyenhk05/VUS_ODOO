<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Record Rule: Teacher (Giáo viên) trên bảng điểm danh -->
        <record id="rule_vus_attendance_sheet_teacher" model="ir.rule">
            <field name="name">Giáo viên bảng điểm danh lớp mình</field>
            <field name="model_id" ref="model_vus_attendance_sheet"/>
            <field name="domain_force">[('teacher_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('vus_student.group_vus_teacher'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Record Rule: Staff & Manager trên bảng điểm danh -->
        <record id="rule_vus_attendance_sheet_all" model="ir.rule">
            <field name="name">Quản lý Staff bảng điểm danh all</field>
            <field name="model_id" ref="model_vus_attendance_sheet"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('vus_student.group_vus_staff')), (4, ref('vus_student.group_vus_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Record Rule: Teacher (Giáo viên) chi tiết điểm danh -->
        <record id="rule_vus_attendance_teacher" model="ir.rule">
            <field name="name">Giáo viên list điểm danh lớp mình</field>
            <field name="model_id" ref="model_vus_attendance"/>
            <field name="domain_force">[('teacher_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('vus_student.group_vus_teacher'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Record Rule: Staff & Manager chi tiết điểm danh -->
        <record id="rule_vus_attendance_all" model="ir.rule">
            <field name="name">Quản lý Staff list điểm danh all</field>
            <field name="model_id" ref="model_vus_attendance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('vus_student.group_vus_staff')), (4, ref('vus_student.group_vus_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
