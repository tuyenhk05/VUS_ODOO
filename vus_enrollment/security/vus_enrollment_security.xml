<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Record Rule: Teacher (Giáo viên) chỉ đọc phiếu ghi danh của lớp mình dạy -->
        <record id="rule_vus_enrollment_teacher" model="ir.rule">
            <field name="name">Giáo viên đọc phiếu ghi danh lớp mình</field>
            <field name="model_id" ref="model_vus_enrollment"/>
            <field name="domain_force">[('class_id.teacher_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('vus_student.group_vus_teacher'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Record Rule: Staff & Manager toàn quyền -->
        <record id="rule_vus_enrollment_all" model="ir.rule">
            <field name="name">Quản lý Staff xem toàn bộ phiếu ghi danh</field>
            <field name="model_id" ref="model_vus_enrollment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('vus_student.group_vus_staff')), (4, ref('vus_student.group_vus_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
