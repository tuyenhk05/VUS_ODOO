<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_vus_course_tree" model="ir.ui.view">
        <field name="name">vus.course.tree</field>
        <field name="model">vus.course</field>
        <field name="arch" type="xml">
            <tree string="Danh sách khóa học">
                <field name="code"/>
                <field name="course_name"/>
                <field name="level" widget="badge" decoration-info="level == 'starter'" decoration-success="level == 'beginner'"/>
                <field name="base_price" sum="Tổng học phí"/>
            </tree>
        </field>
    </record>

    <!-- Kanban View - CỰC KỲ ĐƠN GIẢN ĐỂ TEST LỖI -->
    <record id="view_vus_course_kanban" model="ir.ui.view">
        <field name="name">vus.course.kanban</field>
        <field name="model">vus.course</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="course_name"/>
                <field name="level"/>
                <field name="code"/>
                <field name="base_price"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="course_name"/></strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <span t-attf-class="badge rounded-pill #{record.level.raw_value == 'beginner' ? 'text-bg-success' : 'text-bg-info'}">
                                    <field name="level"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_bottom mt-2">
                                <div class="oe_kanban_bottom_left">
                                    <field name="code"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <strong class="text-primary"><field name="base_price"/></strong>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_vus_course_form" model="ir.ui.view">
        <field name="name">vus.course.form</field>
        <field name="model">vus.course</field>
        <field name="arch" type="xml">
            <form string="Khóa học">
                <header name="course_header">
                    <button name="action_confirm" string="Xác nhận áp dụng" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_close" string="Ngưng áp dụng" type="object" class="btn-secondary" invisible="state != 'confirmed'"/>
                    <button name="action_set_draft" string="Đặt về nháp" type="object" invisible="state != 'closed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <div class="oe_title">
                        <h1>
                            <field name="course_name" placeholder="Tên khóa học..."/>
                        </h1>
                        <div class="oe_subtitle">
                            <field name="code" placeholder="Mã khóa học"/>
                        </div>
                    </div>
                    <group>
                        <group>
                            <field name="level"/>
                            <field name="base_price"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="duration_weeks"/>
                            <field name="sessions_per_week"/>
                            <field name="hours_per_session"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Mô tả">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_vus_course_search" model="ir.ui.view">
        <field name="name">vus.course.search</field>
        <field name="model">vus.course</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm khóa học">
                <field name="course_name"/>
                <field name="code"/>
                <filter name="level" string="Trình độ" domain="[]" context="{'group_by': 'level'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_vus_course" model="ir.actions.act_window">
        <field name="name">Khóa học</field>
        <field name="res_model">vus.course</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo khóa học mới!
            </p>
        </field>
    </record>
</odoo>
