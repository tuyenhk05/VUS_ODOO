<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="view_vus_class_tree" model="ir.ui.view">
        <field name="name">vus.class.tree</field>
        <field name="model">vus.class</field>
        <field name="arch" type="xml">
            <tree string="Danh sách lớp học" 
                  decoration-success="state == 'opened'" 
                  decoration-info="state == 'draft'" 
                  decoration-danger="state == 'full'" 
                  decoration-muted="state == 'closed'">
                <field name="class_code"/>
                <field name="class_name"/>
                <field name="course_id"/>
                <field name="teacher_id"/>
                <field name="state" widget="badge" 
                       decoration-success="state == 'opened'" 
                       decoration-info="state == 'draft'" 
                       decoration-danger="state == 'full'" 
                       decoration-muted="state == 'closed'"/>
            </tree>
        </field>
    </record>

    <!-- Kanban View - CỰC KỲ ĐƠN GIẢN ĐỂ TEST LỖI -->
    <record id="view_vus_class_kanban" model="ir.ui.view">
        <field name="name">vus.class.kanban</field>
        <field name="model">vus.class</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="class_name"/>
                <field name="teacher_name"/>
                <field name="schedule"/>
                <field name="class_code"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="class_name"/></strong>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><i class="fa fa-user"/> <field name="teacher_name"/></div>
                                <div><i class="fa fa-calendar"/> <field name="schedule"/></div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <field name="class_code"/>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <span t-attf-class="badge rounded-pill #{record.state.raw_value === 'opened' ? 'text-bg-success' : (record.state.raw_value === 'full' ? 'text-bg-danger' : 'text-bg-info')}">
                                        <field name="state"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_vus_class_form" model="ir.ui.view">
        <field name="name">vus.class.form</field>
        <field name="model">vus.class</field>
        <field name="arch" type="xml">
            <form string="Lớp học">
                <header>
                    <button name="action_open_class" string="Mở lớp học" type="object" class="oe_highlight" invisible="state != 'draft'" groups="vus_student.group_vus_staff,vus_student.group_vus_manager"/>
                    <button name="action_close_class" string="Kết thúc lớp học" type="object" class="oe_highlight" invisible="state not in ['opened', 'full']" groups="vus_student.group_vus_staff,vus_student.group_vus_manager"/>
                    <button name="action_cancel_class" string="Hủy lớp học" type="object" class="btn-secondary" invisible="state not in ['draft', 'opened']" groups="vus_student.group_vus_staff,vus_student.group_vus_manager"/>
                    <button name="action_set_draft" string="Đặt về nháp" type="object" invisible="state not in ['closed', 'cancelled']" groups="vus_student.group_vus_staff,vus_student.group_vus_manager"/>
                    <button name="action_remove_unpaid_students" string="Hủy xếp lớp học viên chưa đóng phí" type="object" class="btn-danger" invisible="state not in ['opened', 'full']" groups="vus_student.group_vus_staff,vus_student.group_vus_manager"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,opened,full,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="class_name" placeholder="Tên lớp..."/>
                        </h1>
                        <div class="oe_subtitle">
                            <field name="class_code" placeholder="Mã lớp"/>
                        </div>
                    </div>
                    <group>
                        <group>
                            <field name="course_id"/>
                            <field name="teacher_id"/>
                            <field name="max_students"/>
                        </group>
                        <group>
                            <field name="schedule"/>
                            <field name="classroom"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="payment_deadline"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_vus_class" model="ir.actions.act_window">
        <field name="name">Lớp học</field>
        <field name="res_model">vus.class</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Tạo lớp học mới!
            </p>
        </field>
    </record>

    <!-- Inherit Course Form to add Smart Button -->
    <record id="view_vus_course_form_inherit_class" model="ir.ui.view">
        <field name="name">vus.course.form.inherit.class</field>
        <field name="model">vus.course</field>
        <field name="inherit_id" ref="vus_course.view_vus_course_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_classes" type="object" class="oe_stat_button" icon="fa-bars">
                    <field name="class_count" widget="statinfo" string="Lớp học"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
