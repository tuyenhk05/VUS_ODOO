<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Record Rule: Teacher (Giáo viên) chỉ thấy lớp của mình -->
        <record id="rule_vus_class_teacher" model="ir.rule">
            <field name="name">Giáo viên chỉ thấy lớp của mình</field>
            <field name="model_id" ref="model_vus_class"/>
            <field name="domain_force">[('teacher_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('vus_student.group_vus_teacher'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Record Rule: Manager & Staff (Tuyển sinh/Quản lý) thấy toàn bộ lớp -->
        <record id="rule_vus_class_all" model="ir.rule">
            <field name="name">Quản lý và Tuyển sinh thấy toàn bộ lớp</field>
            <field name="model_id" ref="model_vus_class"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('vus_student.group_vus_staff')), (4, ref('vus_student.group_vus_manager'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
