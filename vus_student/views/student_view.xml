<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_vus_student" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.vus.student</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Tìm đến trường category_id (Tags) và chèn vào phía sau -->
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="is_student" widget="boolean_toggle"/>
                <field name="student_code" invisible="not is_student" required="is_student"/>
                <field name="dob" invisible="not is_student"/>
                <field name="student_status" invisible="not is_student"/>
            </xpath>
        </field>
    </record>
</odoo>

